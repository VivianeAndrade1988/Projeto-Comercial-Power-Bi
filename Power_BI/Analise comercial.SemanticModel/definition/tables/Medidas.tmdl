	measure 'Valor Coluna Faturamento' = ```
			
			VAR vFat = [$ Faturamento]
			VAR vFatFormat = 
			SWITCH(
			    TRUE(),
			    vFat > 1E6, FORMAT(vFat, "#0,, Mi"),
			    vFat > 1E3, FORMAT(vFat, "#0, K"),
			    FORMAT(vFat, "#0")
			)
			RETURN
			vFatFormat
			```
		displayFolder: UX
		lineageTag: e7d62e61-c94b-4e87-a347-b540d0b4e681

