	measure 'Melhor Mês FAT' = ```
			
			VAR TabelaMeses =
			    ADDCOLUMNS(
			        SUMMARIZE(
			            dCalendario,
			            dCalendario[Ano],
			            dCalendario[mês int]
			        ),
			        "FatMes", [$ Faturamento]
			    )
			
			VAR TopMes =
