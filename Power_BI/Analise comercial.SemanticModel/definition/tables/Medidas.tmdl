	measure 'Barra de progresso faturamento' = ```
			
			VAR vValor = [% Faturamento ano anterior concluido]   -- ex: 0.94 | 1.06 | 1.40
			VAR vValor_formatado = FORMAT(vValor, "0%")
			
			// ================= FORMATAÇÕES =================
			
			VAR vFonte = "Cambria"
			
			// Texto
			VAR vRotulo_categoria_texto =" "
			VAR vRotulo_categoria_cor = "#3f3f3f"
			VAR vRotulo_categoria_tam = 15
			
			// Valor %
			VAR vRotulo_dados_cor = IF(vValor>=1, "green","red")
			VAR vRotulo_dados_tam = 18
			VAR vRotulo_dados_peso = 700
			VAR vRotulo_dados_posicao = 230
			
			// Barra
			VAR vBarra_altura = 35
			VAR vBarra_cor =IF(vValor>=1, "#6D12B4","red")            
			VAR vBarra_fundo_cor = "#CCCCCC"      -- fundo antes da meta
			VAR vBarra_pos_meta_cor = "#CCCCCC"   -- cinza após a meta
			VAR vBarra_fundo_opacidade = 9
			
			// Linha da meta
			VAR vLinha_meta_larg = 3
			VAR vLinha_meta_cor = "#4A4A4A"
			
			// ================= CÁLCULOS =================
			
			VAR vLargura_base = 190               -- até a meta (100%)
			VAR vLargura_pos_meta = 90            -- trecho cinza após a meta
			VAR vLargura_max = vLargura_base + vLargura_pos_meta
			
			VAR vLargura_barra =
			    MIN(
			        vLargura_max,
			        ROUND(vLargura_base * vValor, 0)
			    )
			
			VAR vPosicao_meta = vLargura_base
			
			RETURN
			"data:image/svg+xml;utf8,
			<svg viewBox='0 0 300 70' xmlns='http://www.w3.org/2000/svg'>
			
			  <!-- Fundo até a meta -->
			  <rect x='0' y='38'
			        width='" & vLargura_base & "'
			        height='" & vBarra_altura & "'
			        fill='" & vBarra_fundo_cor & "'
			        opacity='" & vBarra_fundo_opacidade & "' />
			
			  <!-- Fundo após a meta (SEMPRE visível) -->
			  <rect x='" & vLargura_base & "' y='38'
			        width='" & vLargura_pos_meta & "'
			        height='" & vBarra_altura & "'
			        fill='" & vBarra_pos_meta_cor & "'
			        opacity='" & vBarra_fundo_opacidade & "' />
			
			  <!-- Barra progresso (pode ultrapassar a meta) -->
			  <rect x='0' y='38'
			        width='" & vLargura_barra & "'
			        height='" & vBarra_altura & "'
			        fill='" & vBarra_cor & "' />
			
			  <!-- Linha da meta (por cima de tudo) -->
			  <rect x='" & vPosicao_meta & "' y='33'
			        width='" & vLinha_meta_larg & "'
			        height='" & (vBarra_altura + 10) & "'
			        fill='" & vLinha_meta_cor & "' />
			
			  <!-- Texto Meta -->
			  <text x='0' y='26'
			        fill='" & vRotulo_categoria_cor & "'
			        font-family='" & vFonte & "'
			        font-size='" & vRotulo_categoria_tam & "'>
			        " & vRotulo_categoria_texto & "
			  </text>
			
			  <!-- Valor % -->
			  <text x='" & vRotulo_dados_posicao & "' y='26'
			        fill='" & vRotulo_dados_cor & "'
			        font-family='" & vFonte & "'
			        font-size='" & vRotulo_dados_tam & "'
			        font-weight='" & vRotulo_dados_peso & "'>
			        " & vValor_formatado & "
			  </text>
			
			</svg>"
			
			```
		displayFolder: Barra de progresso
		lineageTag: 0a063b25-2a42-4c6f-85f3-938478d5b068

